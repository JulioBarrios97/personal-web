---
import Layout from "../layouts/Layout.astro";
import Services from "../components/Services.astro";
import Contact from "../components/Contact.astro";
const pageTitle = "Julio Agustín Barrios — Ingeniero de Software";

const experience = [
  {
    role: "Freelance, Ingeniero de Software",
    date: "Feb 2026 - Presente",
    body: "Consultoría técnica (diseño de sistemas, stack y arquitectura) y desarrollo end-to-end: sitios web y e-commerce, videojuegos con Godot, integraciones de APIs, componentes frontend y docencia técnica.",
  },
  {
    role: "Sailing Protocol, Software Engineer",
    date: "Oct 2023 - Ene 2026",
    body: "Desarrollo de una plataforma de tokenización de activos financieros, trabajando en arquitectura y desarrollo end-to-end. Diseño e implementación de un bot de market making rentable: definición de flujos, gestión de riesgo y escalabilidad. Trabajo transversal en backend, frontend y smart contracts.",
  },
  {
    role: "It-techgroup, Blockchain & Web Developer",
    date: "Jul 2022 - Oct 2023",
    body: "Gestioné equipos técnicos y actué como enlace entre técnicos, clientes y directores. Desarrollé y desplegué Smart Contracts, y creé páginas web con herramientas full code y low code.",
  },
  {
    role: "EducaciónIT, Profesor Blockchain",
    date: "Ene 2023 - Feb 2023",
    body: "Profesor a cargo de dictar el curso Blockchain Ethereum Solidity.",
  },
  {
    role: "Shokworks, Blockchain Backend",
    date: "Feb 2022 - Jun 2022",
    body: "Contribuí al desarrollo de Smart Contracts para colecciones de NFT (ERC721) y establecí conexiones cruciales entre el frontend y los Smart Contracts.",
  },
  {
    role: "Freelance, Jr Developer",
    date: "Jul 2021 - Ene 2022",
    body: "Desarrollé bots de trading algorítmico con Python y participé en proyectos blockchain con enfoque en Smart Contracts.",
  },
];
---

<Layout pageTitle={pageTitle} isHome={true}>
  <div class="gif">
    <img width="300" height="350" alt="falloutGif" src="/fallout.gif" />
  </div>
  <br />
  <h1 style="margin-bottom: 12px">Julio Agustín Barrios</h1>
  <p class="tagline">
    <small>Ingeniero de Software</small>
    <span class="tagline-stack">Web · Backend · Blockchain · Consultoría</span>
  </p>

  <div class="button hero-cta">
    <a href="#contacto"><button>Trabajemos juntos</button></a>
    <a href="/projects/"><button class="btn-ghost">Portafolio</button></a>
    <a href="/Software Engineer Julio Barrios.pdf"
      ><button class="btn-ghost">Descargar CV</button></a
    >
  </div>

  <hr />

  <h2>Acerca de mí</h2>
  <p>
    Soy ingeniero de software con más de 5 años en la industria IT, trabajando
    de punta a punta en backend, frontend y blockchain. Integro tecnologías
    modernas, buenas prácticas y procesos completos de desarrollo en cada
    proyecto.
  </p>
  <p>
    Mi recorrido va del desarrollo end-to-end al diseño de arquitecturas
    complejas, pasando por la docencia en desarrollo blockchain. Esa combinación
    me dio criterio técnico, autonomía y una visión integral del ciclo de vida
    de un producto. Hoy lo pongo al servicio de tu proyecto como freelance.
  </p>

  <Services />

  <h2>Skills</h2>
  <div class="link-images">
    <img width="46" height="46" alt="Solidity" src="/solidity-svgrepo-com.svg" />
    <img width="46" height="46" alt="Nextjs" src="/nextjs-svgrepo-com.svg" />
    <img
      width="46"
      height="46"
      alt="TypeScript"
      src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-plain.svg"
    />
    <img
      width="46"
      height="46"
      alt="Angular"
      src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/angularjs/angularjs-plain.svg"
    />
    <img width="46" height="46" alt="TailwindCSS" src="/tailwind-svgrepo-com.svg" />
    <img
      width="46"
      height="46"
      alt="CSS"
      src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-plain.svg"
    />
    <img
      width="46"
      height="46"
      alt="HTML"
      src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-plain.svg"
    />
    <img
      width="46"
      height="46"
      alt="JavaScript"
      src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-plain.svg"
    />
    <img width="46" height="46" alt="Python" src="/python-svgrepo-com.svg" />
  </div>

  <h2>Experiencia</h2>
  <ul class="timeline">
    {
      experience.map((job) => (
        <li>
          <h3>{job.role}</h3>
          <small>{job.date}</small>
          <p>{job.body}</p>
        </li>
      ))
    }
  </ul>

  <Contact />
</Layout>

<style>
  .tagline {
    margin: 0 0 0.4rem;
    text-indent: 0;
  }

  .tagline-stack {
    display: block;
    color: var(--green-dim);
    font-size: 1rem;
    margin-top: 0.5rem;
    letter-spacing: 1px;
  }

  .hero-cta {
    justify-content: flex-start;
    margin-top: 1.2rem;
  }

  /* Experience as a compact terminal timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0.6rem 0 0;
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.3rem 1.2rem;
    border-left: 1px solid var(--green-faint);
  }

  .timeline li:last-child {
    padding-bottom: 0;
  }

  .timeline li::before {
    content: "";
    position: absolute;
    left: -5px;
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: var(--glow);
  }

  .timeline h3 {
    font-size: 1.25rem;
    margin: 0 0 0.4rem;
    color: var(--green-bright);
  }

  .timeline p {
    font-size: 1rem;
    line-height: 1.35;
    margin: 0.5rem 0 0;
    color: var(--green-dim);
  }
</style>
