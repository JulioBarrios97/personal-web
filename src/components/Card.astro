---
interface Props {
    title: string;
    body: string;
    href: string;
    image: string;
    newTab?: boolean;
}

const { href, image, title, body, newTab = true } = Astro.props;
const target = newTab ? "_blank" : undefined;
const rel = newTab ? "noopener noreferrer" : undefined;
---

<li class="link-card">
    <a href={href} target={target} rel={rel}>
        <div class="img">
            <img
                width="226"
                height="127"
                src={image}
                class="card-img"
                alt={`Captura de ${title}`}
            />
        </div>
        <h3><b>{title}</b></h3>
        <p>
            {body}
        </p>
    </a>
</li>
<style>
    .link-card {
        list-style: none;
        padding: 14px;
    }

    .link-card > a {
        display: block;
        width: 100%;
        text-decoration: none;
        line-height: 1.4;
        border-radius: 8px;
        color: var(--green);
        text-align: center;
    }

    .img {
        text-align: center;
    }

    img {
        width: 100%;
        height: auto;
        max-width: 280px;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid var(--green-faint);
    }

    h3 {
        margin: 0.6rem 0 0;
        font-family: var(--font-term);
        font-size: 1.5rem;
        font-weight: normal;
        text-align: center;
        color: var(--green-bright);
    }

    p {
        font-size: 1em;
        line-height: 1.4;
        text-indent: 0;
        text-align: center;
        margin: 0.4rem 0 0;
        color: var(--green-dim);
    }

    .link-card {
        transition: transform 0.2s ease, filter 0.2s ease;
    }

    .link-card:hover {
        transform: scale(1.04);
        filter: drop-shadow(var(--glow));
    }
</style>
