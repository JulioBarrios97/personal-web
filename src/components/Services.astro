<section id="servicios">
  <h2>Servicios</h2>
  <p class="services-intro">
    Trabajo como ingeniero de software freelance. Estos son los frentes en los
    que puedo ayudarte a llevar tu proyecto de la idea a producción:
  </p>
  <div class="services-grid">
    {
      services.map((s) => (
        <article class="service-card">
          <span class="service-id">{s.id}</span>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </article>
      ))
    }
  </div>
  <div class="button">
    <a href="#contacto"><button>Trabajemos juntos</button></a>
  </div>
</section>

<style>
  .services-intro {
    color: var(--green-dim);
    margin-bottom: 1.2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.9rem;
  }

  .service-card {
    position: relative;
    border: 1px solid var(--green-faint);
    background: var(--green-panel);
    border-radius: 8px;
    padding: 1rem 1.1rem 1.1rem;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }

  .service-card:hover {
    border-color: var(--green);
    box-shadow: var(--glow);
    transform: translateY(-3px);
  }

  .service-id {
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--green-dim);
    letter-spacing: 1px;
  }

  .service-card h3 {
    font-size: 1.3rem;
    line-height: 1.1;
    margin: 0.5rem 0 0.4rem;
    color: var(--green-bright);
  }

  .service-card p {
    font-size: 1rem;
    line-height: 1.4;
    margin: 0;
    color: var(--green-text);
  }
</style>
