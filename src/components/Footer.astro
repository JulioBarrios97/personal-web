---
const year = new Date().getFullYear();
---

<footer>
    <p class="footer-cta">¿Arrancamos un proyecto? <a href="/#contacto">Hablemos →</a></p>
    <div class="social-icons">
        <a
            href="https://www.linkedin.com/in/julio-agustin-barrios/"
            target="_blank"
            aria-label="LinkedIn"
        >
            <img src="/linkedin-icon.svg" alt="LinkedIn" width="30" height="30" />
        </a>
        <a href="https://github.com/JulioBarrios97" target="_blank" aria-label="GitHub">
            <img src="/github-icon.svg" alt="GitHub" width="30" height="30" />
        </a>
        <a href="mailto:julioagbarrios@gmail.com" aria-label="Email">
            <img src="/mail-icon.svg" alt="Email" width="30" height="30" />
        </a>
    </div>
    <small class="copyright">© {year} Julio Agustín Barrios</small>
</footer>
<style>
    footer {
        text-align: center;
        padding: 2rem 1rem 3rem;
        margin-top: 4rem;
        border-top: 1px solid var(--green-faint);
    }

    .footer-cta {
        text-indent: 0;
        font-size: 1.15rem;
        color: var(--green-dim);
        margin-bottom: 1.4rem;
    }

    .footer-cta a {
        color: var(--green-bright);
        text-decoration: none;
    }

    .footer-cta a:hover {
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .social-icons {
        display: flex;
        justify-content: center;
        gap: 1.2rem;
        margin-bottom: 1.2rem;
    }

    .social-icons a {
        color: var(--green);
        line-height: 0;
    }

    .social-icons a img {
        transition: transform 0.25s ease, filter 0.25s ease;
    }

    .social-icons a:hover img {
        transform: scale(1.2);
        filter: drop-shadow(var(--glow));
    }

    .copyright {
        border: none;
        background: none;
        color: var(--green-dim);
        font-size: 0.95rem;
        padding: 0;
    }
</style>
