---
const { isHome = false } = Astro.props;
const base = isHome ? "" : "/";
---
<div class="nav-bar">
    <div class="title-link">
        <a href="/">JAB</a>
    </div>
    <div class="nav-links">
        <a href={`${base}#servicios`}>Servicios</a>
        <a href="/projects/">Proyectos</a>
        <a href={`${base}#contacto`}>Contacto</a>
        <span class="nav-sep"></span>
        <a class="nav-social" href="https://github.com/JulioBarrios97" target="_blank" aria-label="GitHub">
            <img src="/github-icon.svg" alt="GitHub" width="22" height="22" />
        </a>
        <a class="nav-social" href="https://www.linkedin.com/in/julio-agustin-barrios/" target="_blank" aria-label="LinkedIn">
            <img src="/linkedin-icon.svg" alt="LinkedIn" width="22" height="22" />
        </a>
    </div>
</div>
