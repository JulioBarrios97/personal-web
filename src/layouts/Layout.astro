---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const { pageTitle, isHome = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="description" content="Julio Agustín Barrios — Ingeniero de software freelance. Desarrollo web y e-commerce, backend & APIs, blockchain y smart contracts, consultoría técnica.">
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
        <Header isHome={isHome} />
		<slot />
        <Footer />
	</body>
</html>
